# URL del servidor en Render
SERVER_URL=https://buenaburger-pos.onrender.com

# Secreto compartido con el servidor (mismo valor que AGENT_SECRET en .env del servidor)
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AGENT_SECRET=CAMBIAR_POR_SECRETO_ALEATORIO

# IP local de la impresora WiFi ESC/POS en la red del local
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
