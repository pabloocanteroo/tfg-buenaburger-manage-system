# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio (ya está en .gitignore).

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Crea un usuario con permisos readWrite solo sobre la BD 'buenaburger'.
# NO reutilices una contraseña débil ni basada en el nombre del negocio.
MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/<basededatos>

PORT=3000
NODE_ENV=development

# ── JWT ───────────────────────────────────────────────────────────────────────
# Genera un secreto aleatorio de 64 bytes con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_64_BYTES_RANDOM_EN_HEX
JWT_EXPIRES_IN=7d

# ── CORS ──────────────────────────────────────────────────────────────────────
# Orígenes permitidos en producción (separados por coma).
# Ej: ALLOWED_ORIGINS=https://tudominio.com,https://admin.tudominio.com
ALLOWED_ORIGINS=

# ── Impresora WiFi ESC/POS (TCP puerto 9100) ──────────────────────────────────
PRINTER_IP=
PRINTER_PORT=9100

# ── Seed del admin inicial ────────────────────────────────────────────────────
# Requeridos al ejecutar `node src/seed.js`. La password debe ser fuerte
# (20+ caracteres, mezcla de tipos). No la documentes en ningún commit.
SEED_ADMIN_EMAIL=admin@buenaburger.es
SEED_ADMIN_PASSWORD=CAMBIAR_POR_PASSWORD_FUERTE
