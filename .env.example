# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el .env al repositorio (ya está en .gitignore).

MONGODB_URI=mongodb+srv://<usuario>:<password>@cluster.mongodb.net/<basededatos>
PORT=3000
NODE_ENV=development

# Genera un secreto seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambiame_por_un_secreto_seguro
JWT_EXPIRES_IN=7d

# Orígenes permitidos para CORS en producción (separados por coma)
# ALLOWED_ORIGINS=https://tudominio.com,https://admin.tudominio.com
ALLOWED_ORIGINS=

# Impresora WiFi ESC/POS (TCP puerto 9100)
PRINTER_IP=
PRINTER_PORT=9100
